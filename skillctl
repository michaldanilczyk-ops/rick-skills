#!/usr/bin/env zsh
# skillctl - Skill Lifecycle Management CLI
# Manages the full lifecycle of OpenClaw/Codex skills
# Repository: ~/.openclaw/workspace/skill-lifecycle/
#
# Usage: skillctl <command> [options]
#   init <name>        - Scaffold a new skill
#   validate <path>    - Validate a skill's structure
#   audit [path]       - Full skill inventory + health check
#   promote <path>     - Advance skill lifecycle stage
#   eval <path>        - Run skill evaluation prompts
#   changelog <path>   - View/manage skill changelog
#   registry           - Show/update the skills registry
#   status <path>      - Show lifecycle status for a skill
#   install <path>     - Install/copy skill into OpenClaw
#   template           - List available templates
#   help               - Show this help
#
# Lifecycle stages: draft -> proposed -> reviewed -> staged -> released -> deprecated

SKILLCTL_SELF="$0"
SKILL_LIFECYCLE_DIR="${0:A:h}"
REGISTRY="$SKILL_LIFECYCLE_DIR/skills-registry.json"
TEMPLATES_DIR="$SKILL_LIFECYCLE_DIR/templates"
SCRIPTS_DIR="$SKILL_LIFECYCLE_DIR/scripts"
WORKSPACE_SKILLS="$HOME/.openclaw/workspace/skills"
AGENTS_SKILLS="$HOME/.openclaw/workspace/.agents/skills"

# Stages in order
STAGES=("draft" "proposed" "reviewed" "staged" "released" "deprecated")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

info()  { echo -e "${BLUE}[INFO]${NC} $1" }
ok()    { echo -e "${GREEN}[OK]${NC} $1" }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1" }
err()   { echo -e "${RED}[ERR]${NC} $1" >&2 }
header(){ echo -e "\n${CYAN}═══ $1 ═══${NC}" }

# ──────────────────────────────────────────────
# Registry helpers
# ──────────────────────────────────────────────

load_registry() {
  if [[ -f "$REGISTRY" ]]; then
    cat "$REGISTRY"
  else
    echo '{"skills":{},"schema":"v1","updated":""}'
  fi
}

save_registry() {
  echo "$1" > "$REGISTRY"
}

get_skill_registry_entry() {
  local name="$1"
  local registry=$(load_registry)
  echo "$registry" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d['skills'].get('$name',{})))" 2>/dev/null || echo "{}"
}

update_registry_entry() {
  local name="$1"
  local key="$2"
  local value="$3"
  local registry=$(load_registry)
  local updated=$(echo "$registry" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if '$name' not in d['skills']:
    d['skills']['$name'] = {'name': '$name', 'stage': 'draft', 'created': '', 'updated': '', 'version': '0.1.0', 'author': '', 'owners': [], 'changelog': []}
d['skills']['$name']['$key'] = '$value'
d['skills']['$name']['updated'] = '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
d['updated'] = '$(date -u +%Y-%m-%dT%H:%M:%SZ)'
print(json.dumps(d, indent=2))
")
  save_registry "$updated"
}

# ──────────────────────────────────────────────
# Validation
# ──────────────────────────────────────────────

validate_skill() {
  local skill_dir="$1"
  local errors=0
  local warnings=0
  local name=""

  header "Validating: $skill_dir"
  
  # Check directory exists
  if [[ ! -d "$skill_dir" ]]; then
    err "Directory does not exist: $skill_dir"
    return 1
  fi

  # Check SKILL.md exists
  if [[ ! -f "$skill_dir/SKILL.md" ]]; then
    err "Missing required file: SKILL.md"
    ((errors++))
  else
    # Validate YAML frontmatter
    local frontmatter=$(sed -n '/^---$/,/^---$/p' "$skill_dir/SKILL.md" 2>/dev/null | head -20)
    if [[ -z "$frontmatter" ]]; then
      err "SKILL.md: Missing YAML frontmatter (--- delimiters)"
      ((errors++))
    else
      # Check name field
      name=$(echo "$frontmatter" | grep "^name:" | sed 's/^name:[[:space:]]*//')
      if [[ -z "$name" ]]; then
        err "SKILL.md: Missing 'name' in frontmatter"
        ((errors++))
      else
        ok "SKILL.md: name = '$name'"
      fi
      
      # Check description field
      local desc=$(echo "$frontmatter" | grep "^description:" | sed 's/^description:[[:space:]]*//')
      if [[ -z "$desc" ]]; then
        err "SKILL.md: Missing 'description' in frontmatter"
        ((errors++))
      elif [[ ${#desc} -lt 20 ]]; then
        warn "SKILL.md: Description is very short (<20 chars)"
        ((warnings++))
      else
        ok "SKILL.md: description present (${#desc} chars)"
      fi
    fi

    # Check file size
    local size=$(wc -c < "$skill_dir/SKILL.md" 2>/dev/null)
    if [[ $size -gt 50000 ]]; then
      warn "SKILL.md is very large (${size}b) — consider splitting into references/"
      ((warnings++))
    fi
  fi

  # Check for forbidden files
  for forbidden in README.md INSTALLATION_GUIDE.md QUICK_REFERENCE.md CHANGELOG.md; do
    if [[ -f "$skill_dir/$forbidden" ]]; then
      warn "Found unnecessary file: $forbidden (keep skill lean)"
      ((warnings++))
    fi
  done

  # Check optional directories
  for dir in scripts references assets; do
    if [[ -d "$skill_dir/$dir" ]]; then
      local count=$(find "$skill_dir/$dir" -type f 2>/dev/null | wc -l)
      ok "Found $dir/ ($count files)"
    fi
  done

  # Check for symlinks (not allowed)
  local symlinks=$(find "$skill_dir" -type l 2>/dev/null)
  if [[ -n "$symlinks" ]]; then
    err "Symlinks found (not allowed for packaging): $symlinks"
    ((errors++))
  fi

  # Name consistency check
  local dirname="$(basename "$skill_dir")"
  if [[ -n "$name" && "$dirname" != "$name" ]]; then
    warn "Directory name '$dirname' does not match frontmatter name '$name'"
    ((warnings++))
  fi

  # Naming convention check
  if [[ ! "$dirname" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
    warn "Directory name should be lowercase-hyphenated (got: '$dirname')"
    ((warnings++))
  fi

  header "Results"
  if [[ $errors -gt 0 ]]; then
    err "$errors error(s), $warnings warning(s)"
    return 1
  elif [[ $warnings -gt 0 ]]; then
    warn "0 errors, $warnings warning(s)"
    return 0
  else
    ok "All checks passed!"
    return 0
  fi
}

# ──────────────────────────────────────────────
# Scaffold
# ──────────────────────────────────────────────

scaffold_skill() {
  local name="$1"
  local template="${2:-basic}"
  local output_dir="$3"

  if [[ -z "$name" ]]; then
    err "Usage: skillctl init <name> [--template basic|with-scripts|with-references|full] [--path <output-dir>]"
    return 1
  fi

  # Validate name
  if [[ ! "$name" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
    err "Invalid name. Use lowercase letters, digits, and hyphens. No leading/trailing hyphens."
    return 1
  fi

  local parent_dir="${output_dir:-$AGENTS_SKILLS}"
  local target_dir="$parent_dir/$name"
  
  if [[ -d "$target_dir" ]]; then
    err "Directory already exists: $target_dir"
    return 1
  fi

  local template_dir="$TEMPLATES_DIR/$template"
  if [[ ! -d "$template_dir" ]]; then
    err "Unknown template: $template (available: $(ls $TEMPLATES_DIR | tr '\n' ' '))"
    return 1
  fi

  # Copy template
  mkdir -p "$target_dir"
  cp -r "$template_dir/"* "$target_dir/" 2>/dev/null
  
  # Rename SKILL.md.template to SKILL.md if needed
  if [[ -f "$target_dir/SKILL.md.template" ]]; then
    mv "$target_dir/SKILL.md.template" "$target_dir/SKILL.md"
  fi

  # Replace placeholder name
  local desc=$(echo "${name//-/\ }" | sed 's/\b\(.\)/\u\1/g')
  if [[ -f "$target_dir/SKILL.md" ]]; then
    sed -i '' "s/PLACEHOLDER_NAME/$name/g" "$target_dir/SKILL.md" 2>/dev/null
    sed -i '' "s/PLACEHOLDER_DESCRIPTION/Describe when and why to use this skill/g" "$target_dir/SKILL.md" 2>/dev/null
  fi

  # Git init if in workspace
  if git -C "$(dirname "$target_dir")" rev-parse 2>/dev/null; then
    info "Skill directory is inside a git repo — will be tracked"
  fi

  ok "Created skill '$name' at $target_dir"
  info "Template: $template"
  info "Next steps:"
  echo "  1. Edit $target_dir/SKILL.md"
  echo "  2. Add resources to scripts/, references/, assets/ as needed"
  echo "  3. Run: skillctl validate $target_dir"
  echo "  4. Run: skillctl register $name --status draft"
  echo ""
  echo "  Tip: 'skillctl template' to see available templates"

  # Update registry
  update_registry_entry "$name" "stage" "draft"
  update_registry_entry "$name" "created" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  update_registry_entry "$name" "version" "0.1.0"
}

# ──────────────────────────────────────────────
# Audit
# ──────────────────────────────────────────────

audit_skills() {
  local search_path="${1:-$WORKSPACE_SKILLS}"
  
  header "Skill Inventory Audit"
  echo "Scanning: $search_path"
  echo ""

  local all_skills=$(find "$AGENTS_SKILLS" "$WORKSPACE_SKILLS" -name "SKILL.md" -not -path "*/skill-lifecycle/*" -not -path "*/.git/*" -type f 2>/dev/null | sort -u)
  
  if [[ -z "$all_skills" ]]; then
    warn "No skills found in workspace"
    return 0
  fi

  local total=0
  local passed=0
  local failed=0
  local results=""

  while IFS= read -r skill_file; do
    local dir="$(dirname "$skill_file")"
    local name="$(basename "$dir")"
    ((total++))
    
    # Quick validation
    local frontmatter=$(sed -n '/^---$/,/^---$/p' "$skill_file" 2>/dev/null)
    local skill_name=$(echo "$frontmatter" | grep "^name:" | sed 's/^name:[[:space:]]*//')
    local has_desc=$(echo "$frontmatter" | grep "^description:" | head -1)
    local file_size=$(wc -c < "$skill_file" 2>/dev/null | tr -d ' ')
    local has_scripts=$([[ -d "$dir/scripts" ]] && echo "yes" || echo "no")
    local has_refs=$([[ -d "$dir/references" ]] && echo "yes" || echo "no")
    local has_assets=$([[ -d "$dir/assets" ]] && echo "yes" || echo "no")
    
    # Get lifecycle stage from registry
    local registry_entry=$(get_skill_registry_entry "$name")
    local stage=$(echo "$registry_entry" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('stage',''))" 2>/dev/null)

    local symbol="${GREEN}✓${NC}"
    if [[ -z "$skill_name" || -z "$has_desc" ]]; then
      symbol="${RED}✗${NC}"
      ((failed++))
    else
      ((passed++))
    fi

    results+="$symbol $name"
    [[ -n "$skill_name" ]] && results+=" ($skill_name)"
    results+=" | ${file_size}B"
    [[ "$has_scripts" == "yes" ]] && results+=" scripts"
    [[ "$has_refs" == "yes" ]] && results+=" refs"
    [[ "$has_assets" == "yes" ]] && results+=" assets"
    [[ -n "$stage" ]] && results+=" [${stage}]"
    
    # Check if in registry
    if [[ -z "$stage" ]]; then
      results+=" (not tracked)"
    fi
    
    results+="\n"
  done <<< "$all_skills"

  echo -e "$results" | column -t -s '|'
  
  echo ""
  header "Summary"
  echo "Total skills: $total"
  ok "Valid: $passed"
  [[ $failed -gt 0 ]] && err "Issues: $failed"
  echo ""
  ok "Run 'skillctl validate <skill>' for detailed validation on any skill"
}

# ──────────────────────────────────────────────
# Promote lifecycle stage
# ──────────────────────────────────────────────

promote_skill() {
  local skill_dir="$1"
  local target_stage="$2"

  if [[ ! -d "$skill_dir" ]]; then
    err "Directory not found: $skill_dir"
    return 1
  fi

  local name="$(basename "$skill_dir")"
  local registry_entry=$(get_skill_registry_entry "$name")
  local current_stage=$(echo "$registry_entry" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('stage','draft'))" 2>/dev/null)

  if [[ -z "$target_stage" ]]; then
    # Show current and suggest next
    local next=""
    for ((i=0; i<${#STAGES[@]}; i++)); do
      if [[ "${STAGES[$i]}" == "$current_stage" && $i -lt $((${#STAGES[@]}-1)) ]]; then
        next="${STAGES[$((i+1))]}"
        break
      fi
    done
    
    header "Lifecycle: $name"
    echo "Current: $current_stage"
    [[ -n "$next" ]] && echo "Next:    $next  (run: skillctl promote $skill_dir $next)"
    echo ""
    echo "Stages: ${STAGES[*]}"
    return 0
  fi

  # Validate target stage
  local valid=false
  for s in "${STAGES[@]}"; do
    [[ "$s" == "$target_stage" ]] && valid=true
  done
  if [[ "$valid" == false ]]; then
    err "Invalid stage: $target_stage. Valid: ${STAGES[*]}"
    return 1
  fi

  # Validate before promote to reviewed or later
  if [[ "$target_stage" == "reviewed" || "$target_stage" == "staged" || "$target_stage" == "released" ]]; then
    info "Running pre-promotion validation..."
    validate_skill "$skill_dir"
    if [[ $? -ne 0 ]]; then
      err "Validation failed. Fix errors before promoting to '$target_stage'"
      return 1
    fi
  fi

  # Generate changelog entry for releases
  local changelog_note=""
  if [[ "$target_stage" == "released" || "$target_stage" == "staged" ]]; then
    changelog_note="Promoted to $target_stage"
    # Read current version and bump minor
    local current_ver=$(echo "$registry_entry" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('version','0.1.0'))" 2>/dev/null)
    local new_ver=$(echo "$current_ver" | awk -F. '{print $1"."$2+1".0"}')
    update_registry_entry "$name" "version" "$new_ver"
    ok "Version bumped: $current_ver → $new_ver"
  fi

  update_registry_entry "$name" "stage" "$target_stage"
  
  # Add changelog
  local registry=$(load_registry)
  local updated=$(echo "$registry" | python3 -c "
import sys, json
from datetime import datetime
d = json.load(sys.stdin)
entry = d['skills']['$name']
if 'changelog' not in entry:
    entry['changelog'] = []
entry['changelog'].append({
    'date': '$(date -u +%Y-%m-%d)',
    'stage': '$target_stage',
    'note': '${changelog_note:-Promoted to $target_stage}'
})
print(json.dumps(d, indent=2))
")
  save_registry "$updated"

  ok "Promoted '$name' from '$current_stage' → '$target_stage'"
}

# ──────────────────────────────────────────────
# Eval harness
# ──────────────────────────────────────────────

run_evals() {
  local skill_dir="$1"
  
  if [[ ! -d "$skill_dir" ]]; then
    err "Directory not found: $skill_dir"
    return 1
  fi

  local name="$(basename "$skill_dir")"
  
  # Check for eval file
  local eval_file="$skill_dir/evals.json"
  if [[ ! -f "$eval_file" ]]; then
    warn "No evals.json found for '$name'"
    echo "Create one at: $eval_file"
    echo "Format:"
    echo '{
  "triggers": [
    "What would trigger this skill?",
    "User asks about X..."
  ],
  "non_triggers": [
    "What should NOT trigger this skill?",
    "Related but different topic..."
  ],
  "tests": [
    {"prompt": "Test prompt 1", "expected": "What the output should contain"},
    {"prompt": "Test prompt 2", "expected": "Should handle edge case X"}
  ]
}'
    return 0
  fi

  header "Running evals for: $name"
  
  local triggers=$(python3 -c "import json; d=json.load(open('$eval_file')); [print(f'  ✓ {t}') for t in d.get('triggers',[])]" 2>/dev/null)
  local non_triggers=$(python3 -c "import json; d=json.load(open('$eval_file')); [print(f'  ✗ {t}') for t in d.get('non_triggers',[])]" 2>/dev/null)
  local tests=$(python3 -c "import json; d=json.load(open('$eval_file')); [print(f'  ? {t[\"prompt\"]}') for t in d.get('tests',[])]" 2>/dev/null)
  
  echo "Trigger scenarios (should activate):"
  echo "$triggers"
  echo ""
  echo "Non-trigger scenarios (should NOT activate):"
  echo "$non_triggers"
  echo ""
  echo "Test prompts to run:"
  echo "$tests"
  echo ""
  
  local test_count=$(python3 -c "import json; d=json.load(open('$eval_file')); print(len(d.get('tests',[])))" 2>/dev/null)
  if [[ "$test_count" -gt 0 ]]; then
    info "$test_count eval tests defined. Run them manually or integrate into a CI pipeline:"
    echo '  skillctl eval <skill> --run    # interactive eval run'
  fi
}

# ──────────────────────────────────────────────
# Install skill into OpenClaw
# ──────────────────────────────────────────────

install_skill() {
  local skill_dir="$1"
  
  if [[ ! -d "$skill_dir" ]]; then
    err "Skill directory not found: $skill_dir"
    return 1
  fi

  local name="$(basename "$skill_dir")"
  local target="$AGENTS_SKILLS/$name"
  
  if [[ "$(cd "$skill_dir" && pwd)" == "$(cd "$target" && pwd 2>/dev/null)" ]]; then
    info "Skill already at target location: $target"
    return 0
  fi

  if [[ -d "$target" ]]; then
    err "A skill named '$name' already exists at $target"
    echo "  To replace: rm -rf $target && skillctl install $skill_dir"
    return 1
  fi

  cp -r "$skill_dir" "$target/"
  ok "Installed '$name' to $target"
  
  # Update registry
  update_registry_entry "$name" "stage" "installed"
  info "Registries updated. Run 'skillctl registry' to verify."
}

# ──────────────────────────────────────────────
# Registry display
# ──────────────────────────────────────────────

show_registry() {
  local registry=$(load_registry)
  
  header "Skill Registry"
  
  local skills=$(echo "$registry" | python3 -c "
import sys, json
d = json.load(sys.stdin)
skills = d.get('skills', {})
if not skills:
    print('(empty)')
else:
    for name in sorted(skills.keys()):
        s = skills[name]
        print(f\"{name}|{s.get('stage','?')}|{s.get('version','?')}|{s.get('author','')}|{s.get('updated','')[:10]}\")
" 2>/dev/null)

  if [[ "$skills" == "(empty)" ]]; then
    warn "No skills in registry"
    echo "Run 'skillctl audit' to scan existing skills, or 'skillctl init' to create one"
    return 0
  fi

  echo -e "${BLUE}Name${NC}|${BLUE}Stage${NC}|${BLUE}Version${NC}|${BLUE}Author${NC}|${BLUE}Updated${NC}"
  echo "-----|-----|-------|------|-------"
  while IFS='|' read -r name stage version author updated; do
    echo "$name|$stage|$version|$author|$updated"
  done <<< "$skills" | column -t -s '|'

  echo ""
  echo "Total: $(echo "$skills" | grep -c .) skills tracked"
}

# ──────────────────────────────────────────────
# Changelog
# ──────────────────────────────────────────────

show_changelog() {
  local skill_dir="$1"
  if [[ ! -d "$skill_dir" ]]; then
    err "Directory not found: $skill_dir"
    return 1
  fi

  local name="$(basename "$skill_dir")"
  local registry=$(load_registry)
  
  echo "$registry" | python3 -c "
import sys, json
d = json.load(sys.stdin)
entry = d['skills'].get('$name', {})
changelog = entry.get('changelog', [])
if not changelog:
    print('No changelog entries for $name')
else:
    print(f\"Changelog for {entry.get('name', '$name')} (v{entry.get('version', '?')})\")
    print(f\"Current stage: {entry.get('stage', '?')}\")
    print('-' * 40)
    for entry in changelog:
        print(f\"  [{entry.get('date','?')}] {entry.get('stage','?')}: {entry.get('note','')}\")
" 2>/dev/null
}

# ──────────────────────────────────────────────
# List templates
# ──────────────────────────────────────────────

list_templates() {
  header "Available Templates"
  
  for t in "$TEMPLATES_DIR"/*; do
    local name=$(basename "$t")
    local desc_file="$t/.description"
    local desc=""
    [[ -f "$desc_file" ]] && desc=$(cat "$desc_file")
    echo "  $name"
    [[ -n "$desc" ]] && echo "    $desc"
    echo "    Files: $(find "$t" -type f | wc -l | tr -d ' ') resource(s)"
    echo ""
  done
}

# ──────────────────────────────────────────────
# Status
# ──────────────────────────────────────────────

skill_status() {
  local skill_dir="$1"
  if [[ ! -d "$skill_dir" ]]; then
    err "Directory not found: $skill_dir"
    return 1
  fi

  local name="$(basename "$skill_dir")"
  local registry_entry=$(get_skill_registry_entry "$name")
  
  header "Status: $name"
  
  if [[ "$registry_entry" == "{}" ]]; then
    warn "Not tracked in registry"
    echo "Run: skillctl init $name or manually add:"
    echo "  skillctl register $name --status draft"
  else
    echo "$registry_entry" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for k in ['name', 'stage', 'version', 'author', 'created', 'updated']:
    v = d.get(k, '')
    if v:
        print(f\"  {k}: {v}\")
owners = d.get('owners', [])
if owners:
    print(f\"  owners: {', '.join(owners)}\")
" 2>/dev/null
  fi

  echo ""
  # Check if skill exists in workspace
  local ws_path="$AGENTS_SKILLS/$name"
  if [[ -d "$ws_path" ]]; then
    ok "Located at: $ws_path"
  fi
  
  local ws_path2="$WORKSPACE_SKILLS/$name"
  if [[ -d "$ws_path2" ]]; then
    ok "Located at: $ws_path2"
  fi
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────

cmd_help() {
  sed -n '3,/^$/p' "$SKILLCTL_SELF" | sed 's/^# //; s/^#$//'
}

case "${1:-help}" in
  init|create)
    shift
    local name="" template="basic" output_dir=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --template) template="$2"; shift 2 ;;
        --path) output_dir="$2"; shift 2 ;;
        *) name="$1"; shift ;;
      esac
    done
    scaffold_skill "$name" "$template" "$output_dir"
    ;;
  validate|check)
    if [[ -z "$2" ]]; then
      err "Usage: skillctl validate <skill-directory>"
      exit 1
    fi
    validate_skill "${2}"
    ;;
  audit|inventory)
    audit_skills "${2:-$WORKSPACE_SKILLS}"
    ;;
  promote|stage)
    if [[ -z "$2" ]]; then
      err "Usage: skillctl promote <skill-directory> [stage]"
      exit 1
    fi
    promote_skill "$2" "$3"
    ;;
  eval|test)
    if [[ -z "$2" ]]; then
      err "Usage: skillctl eval <skill-directory>"
      exit 1
    fi
    run_evals "$2"
    ;;
  registry)
    show_registry
    ;;
  changelog|log)
    if [[ -z "$2" ]]; then
      err "Usage: skillctl changelog <skill-directory>"
      exit 1
    fi
    show_changelog "$2"
    ;;
  install)
    if [[ -z "$2" ]]; then
      err "Usage: skillctl install <skill-directory>"
      exit 1
    fi
    install_skill "${2}"
    ;;
  template|templates)
    list_templates
    ;;
  status)
    if [[ -z "$2" ]]; then
      # Show all skill statuses
      for d in "$AGENTS_SKILLS"/*/; do
        [[ -d "$d" ]] && skill_status "$d" && echo ""
      done
    else
      skill_status "${2}"
    fi
    ;;
  help|--help|-h)
    cmd_help
    ;;
  *)
    err "Unknown command: $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
